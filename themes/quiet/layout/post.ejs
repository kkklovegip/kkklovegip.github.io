<a class="back-link" href="<%- url_for('/') %>">← 返回首页</a>
<article class="post">
  <header class="post-header">
    <div class="article-meta">
      <span><%= page.categories.length ? page.categories.first().name : config.default_category %></span>
      <time datetime="<%= date_xml(page.date) %>"><%= date(page.date, 'YYYY.MM.DD') %></time>
    </div>
    <h1><%= page.title %></h1>
    <% if (page.description) { %><p class="post-lead"><%= page.description %></p><% } %>
  </header>
  <div class="post-body"><%- page.content %></div>
</article>
